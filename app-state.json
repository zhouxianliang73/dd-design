{
  "version": "2026-06-28",
  "brand": "DD design",
  "mainFiles": {
    "html": "1.html",
    "md": "1.md",
    "showcase": "showcase.json",
    "clientPortal": "p.html",
    "teamAdmin": "admin.html"
  },
  "dataFiles": {
    "catalog": "catalog.json",
    "quoteTemplates": "quote-templates.json",
    "channels": "channels.json",
    "showcase": "showcase.json"
  },
  "platform": {
    "domain": "dd-design.com",
    "supabaseSchema": "supabase/schema.sql",
    "configExample": "config.public.example.json",
    "showcasePublic": true,
    "liveProjects": "supabase",
    "magicLinkParam": "t"
  },
  "features": [
    "showcase.json 公开精选案例，与 live project 分离",
    "Supabase live projects + magic link（p.html）",
    "团队 admin.html（≤5 人）",
    "catalog.json → 选品；quote-templates.json → 清单结构",
    "intake 本地归档 → 后续写入 Supabase comm_messages"
  ],
  "localStorageKeys": {
    "commStructure": "deepdesign_comm_structure",
    "teamSession": "dd_design_session"
  },
  "intake": {
    "config": "intake/config.yaml",
    "script": "intake/process_intake.py",
    "projectsDir": "projects",
    "commands": {
      "list": "python intake/process_intake.py list",
      "message": "python intake/process_intake.py message --channel whatsapp --chat \"群名\" --sender 发送者 --text \"内容\"",
      "batch": "python intake/process_intake.py batch path/to/messages.jsonl"
    }
  }
}
