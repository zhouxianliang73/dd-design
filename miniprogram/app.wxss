page {
  background: #f3f4f6;
  color: #374151;
  font-size: 28rpx;
  line-height: 1.5;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.hero {
  margin-bottom: 24rpx;
}

.hero-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4338ca;
  font-size: 22rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-desc,
.muted {
  color: #6b7280;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 8rpx 0 20rpx;
}

.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 22rpx;
}

.btn-primary {
  background: #4b5563;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
}

.btn-ghost {
  background: #ffffff;
  color: #4b5563;
  border: 1rpx solid #d1d5db;
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  color: #9ca3af;
  padding: 48rpx 24rpx;
}

.err {
  color: #dc2626;
}

button {
  margin: 0;
  line-height: normal;
}

button::after {
  border: none;
}

/* 极简产品网格（首页爆款 / 选品共用） */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx 16rpx;
}

.product-card {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.product-image-wrap {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 75%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  background: #f3f4f6;
}

.product-image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #f3f4f6;
}

.product-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 6rpx;
  padding: 0 4rpx;
}

.product-name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 500;
  color: #111827;
  line-height: 1.45;
  min-width: 0;
}

.product-fav-inline {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -2rpx;
}

.product-fav-icon {
  font-size: 32rpx;
  color: #e5e7eb;
  line-height: 1;
  font-weight: 400;
}

.product-fav-active .product-fav-icon {
  color: #e5e7eb;
  font-weight: 400;
}
