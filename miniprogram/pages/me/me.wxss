page {
  background: #f9fafb;
}

.page {
  min-height: 100vh;
  background: #f9fafb;
}

.profile-card {
  margin-bottom: 20rpx;
}

.profile-header {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.big-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: #6b7280;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
}

.member-badge {
  font-size: 20rpx;
  color: #b45309;
  background: #fffbeb;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.profile-email {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.profile-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.profile-stat {
  font-size: 24rpx;
  color: #4b5563;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-header-title {
  font-size: 30rpx;
  font-weight: 600;
}

.card-header-sub {
  font-size: 22rpx;
}

.card-header-more {
  font-size: 24rpx;
}

.benefits-card {
  margin-bottom: 20rpx;
  background: #f3f4f6;
  box-shadow: none;
}

.coupon-scroll {
  width: 100%;
}

.coupon-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.coupon {
  width: 280rpx;
  flex-shrink: 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 12rpx rgba(107, 114, 128, 0.08);
}

.coupon-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #374151;
}

.coupon-sub {
  font-size: 22rpx;
  line-height: 1.4;
  color: #9ca3af;
}

.ongoing-card {
  margin-bottom: 20rpx;
  padding-bottom: 8rpx;
}

.ongoing-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ongoing-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.ongoing-item:last-child {
  border-bottom: none;
}

.ongoing-item:active {
  opacity: 0.9;
}

.ongoing-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.ongoing-name {
  font-size: 28rpx;
  font-weight: 600;
}

.ongoing-meta {
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.ongoing-bottom {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #9ca3af;
  border-radius: 999rpx;
}

.ongoing-price {
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.favorites-card {
  margin-bottom: 20rpx;
}

.favorites-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.favorite-item {
  display: flex;
  gap: 12rpx;
  align-items: center;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 12rpx;
}

.fav-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.fav-img-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.fav-info {
  flex: 1;
  min-width: 0;
}

.fav-name {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-price {
  font-size: 24rpx;
  font-weight: 600;
}

.favorites-empty {
  font-size: 24rpx;
  padding: 8rpx 0;
}

.settings-card {
  margin-bottom: 12rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 28rpx;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  opacity: 0.85;
}

.setting-value,
.setting-arrow {
  font-size: 24rpx;
}

.page-footer {
  text-align: center;
  padding: 24rpx 16rpx 8rpx;
}

.footer-brand {
  display: block;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.footer-legal {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  line-height: 1.6;
  margin-bottom: 4rpx;
}
