.form-card {
  margin-bottom: 24rpx;
}

.form-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
}

.member-badge {
  font-size: 22rpx;
  color: #b45309;
  background: #fffbeb;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #374151;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

.field-input {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
  font-size: 28rpx;
}

.picker-display {
  line-height: 80rpx;
  color: #374151;
}

.field-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.suggest-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.suggest-tag {
  font-size: 24rpx;
  color: #4b5563;
  background: #f3f4f6;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.upload-zone {
  border: 2rpx dashed #d1d5db;
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  background: #fafafa;
  margin-bottom: 16rpx;
}

.upload-zone:active {
  background: #f3f4f6;
}

.upload-icon {
  font-size: 48rpx;
  color: #9ca3af;
  line-height: 1;
  margin-bottom: 12rpx;
}

.upload-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-sub {
  font-size: 24rpx;
}

.pick-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.pick-btn {
  flex: 1;
  margin: 0;
  font-size: 26rpx;
}

.thumb-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.thumb-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.thumb {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #e5e7eb;
}

.thumb-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.75);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  margin-top: 8rpx;
}

.ai-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #ecfdf5, #f0fdf4);
}

.ai-banner-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #07c160;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-banner-text {
  flex: 1;
}

.ai-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.ai-banner-badge {
  font-size: 22rpx;
  color: #07c160;
  background: #fff;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.result-brief {
  margin-bottom: 20rpx;
}

.summary {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.kw-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.kw {
  font-size: 22rpx;
  background: #f3f4f6;
  color: #4b5563;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.results-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title.inline {
  margin: 0;
}

.results-count {
  font-size: 24rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
}

.thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.thumb-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.pinfo {
  flex: 1;
}

.pname {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.price {
  margin-top: 8rpx;
  font-weight: 600;
}

.footer-hint {
  text-align: center;
  font-size: 24rpx;
  margin: 24rpx 0 16rpx;
}

.more-btn {
  width: 100%;
}
