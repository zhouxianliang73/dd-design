.page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.head-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.head-meta {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.head-price {
  font-size: 28rpx;
  font-weight: 700;
}

.address {
  font-size: 22rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  background: #f3f4f6;
  border: none;
  border-radius: 12rpx;
  line-height: 1.3;
}

.payment-summary,
.payment-hint {
  font-size: 22rpx;
  line-height: 1.5;
}

.proj-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.proj-section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.proj-section-label {
  font-size: 28rpx;
  font-weight: 600;
}

.proj-section-bd {
  padding: 0 24rpx 20rpx;
}

.quote-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
}

.step-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.step-label {
  flex: 1;
}

.step-state {
  color: #15803d;
  font-size: 22rpx;
}

.track-row {
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.track-date {
  font-size: 22rpx;
  display: block;
}

.track-text {
  font-size: 26rpx;
}

.track-line {
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.delivery-hint {
  font-size: 22rpx;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.ship-block {
  margin-top: 16rpx;
}

.ship-block-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.ship-photo-group {
  margin-top: 16rpx;
}

.doc-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.doc-item {
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.doc-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.doc-text {
  flex: 1;
  min-width: 0;
}

.doc-name {
  font-size: 26rpx;
  display: block;
}

.doc-note {
  font-size: 22rpx;
  display: block;
  margin-top: 4rpx;
}

.track-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.track-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 14rpx 0;
  background: #111827;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  line-height: 1.3;
}

.track-btn-ghost {
  background: #f3f4f6;
  color: #374151;
}

.track-sync-hint {
  font-size: 22rpx;
  margin-bottom: 8rpx;
  color: #15803d;
}

.track-api-hint {
  font-size: 22rpx;
  line-height: 1.5;
  margin-bottom: 16rpx;
  padding: 12rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.img-strip-row {
  display: flex;
  gap: 12rpx;
}

.img-strip-item {
  width: 160rpx;
  flex-shrink: 0;
}

.strip-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #e5e7eb;
}

.strip-note {
  font-size: 20rpx;
  margin-top: 6rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 24rpx;
}

.badge {
  font-size: 22rpx;
  background: #ecfdf5;
  color: #15803d;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.muted {
  color: #6b7280;
}

.chevron {
  color: #9ca3af;
}
