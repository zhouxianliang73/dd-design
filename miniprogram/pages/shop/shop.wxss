.search {
  margin-bottom: 20rpx;
}

.search-meta {
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.search-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 72rpx;
}

.search-btn-capsule {
  flex-shrink: 0;
  margin: 0;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #fff;
  border: none;
  min-width: 0;
}

.search-btn-capsule::after {
  border: none;
}

.clear-link {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.filter {
  margin-bottom: 20rpx;
}

.filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.filter-head-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-head-space {
  flex: 1;
  min-width: 0;
}

.filter-head-chips {
  flex: 1;
  min-width: 0;
}

.filter-picker-inline {
  width: 100%;
}

.filter-dropdown-grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.filter-head-title {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 600;
}

.filter-clear {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #07c160;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.filter-tag {
  font-size: 22rpx;
  color: #4b5563;
  background: #f3f4f6;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.filter-row {
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-row-sub {
  background: #eff6ff;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  padding: 12rpx 12rpx 4rpx;
}

.filter-row-sub .filter-label {
  color: #1d4ed8;
}

.filter-row-sub .chip {
  background: #fff;
  border-color: #bfdbfe;
}

.filter-row-sub .chip-active {
  background: #2563eb;
  border-color: #2563eb;
  color: #fff;
}

.filter-dropdown-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.filter-picker {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 10rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 20rpx;
  box-sizing: border-box;
}

.filter-picker-sub {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.filter-picker-sub .filter-picker-label {
  color: #1d4ed8;
}

.filter-picker-sub .filter-picker-value {
  color: #1e40af;
}

.filter-picker-disabled {
  opacity: 0.55;
}

.filter-picker-label {
  color: #6b7280;
  flex-shrink: 0;
  font-size: 20rpx;
}

.filter-picker-value {
  flex: 1;
  min-width: 0;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
}

.filter-picker-arrow {
  color: #9ca3af;
  flex-shrink: 0;
  font-size: 20rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.filter-scroll {
  width: 100%;
}

.filter-chips {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.chip {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #4b5563;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 999rpx;
}

.chip-active {
  background: #4b5563;
  border-color: #4b5563;
  color: #fff;
}

.results-meta {
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.product-card {
  padding: 0;
  overflow: hidden;
}

.product-image-wrap {
  position: relative;
}

.product-fav {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(17, 24, 39, 0.1);
}

.product-fav-active {
  background: #fff1f2;
}

.product-fav-icon {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1;
}

.product-fav-active .product-fav-icon {
  color: #e11d48;
}

.product-image {
  width: 100%;
  height: 220rpx;
  display: block;
  background: #e5e7eb;
}

.product-image-placeholder {
  width: 100%;
  height: 220rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.product-body {
  padding: 20rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.product-meta {
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
}
