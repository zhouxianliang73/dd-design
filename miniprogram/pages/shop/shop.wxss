.shop-page {
  padding-top: 8rpx;
}

.pick-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx !important;
  background: #f9fafb;
  box-shadow: none;
}

.pick-banner-body {
  flex: 1;
  min-width: 0;
}

.pick-banner-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4rpx;
}

.pick-banner-sub {
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.pick-banner-hint {
  font-size: 22rpx;
}

.pick-banner-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.pick-banner-link {
  font-size: 24rpx;
  color: #4b5563;
}

.search-panel {
  margin-bottom: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 8rpx;
  font-size: 28rpx;
  color: #111827;
  background: transparent;
  border: none;
}

.search-btn-capsule {
  flex-shrink: 0;
  box-sizing: border-box;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  border: 1rpx solid #e5e7eb;
}

.search-btn-icon {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 4rpx 4rpx;
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.2;
  max-width: 200rpx;
}

.filter-pill text:first-child {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}

.filter-pill.is-active {
  background: #fff;
  border-color: #9ca3af;
  color: #111827;
}

.filter-chevron {
  flex-shrink: 0;
  font-size: 18rpx;
  color: #9ca3af;
  line-height: 1;
}

.search-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 0 4rpx;
}

.result-count {
  font-size: 22rpx;
}

.clear-link {
  font-size: 22rpx;
  color: #6b7280;
}

.empty {
  text-align: center;
  color: #9ca3af;
  padding: 48rpx 24rpx;
  font-size: 26rpx;
}
