.cover-wrap {
  position: relative;
}

.cover {
  width: 100%;
  height: 420rpx;
  display: block;
  background: #e5e7eb;
}

.fav-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(17, 24, 39, 0.12);
}

.fav-active {
  background: rgba(255, 255, 255, 0.92);
}

.fav-icon {
  font-size: 36rpx;
  color: #e5e7eb;
  line-height: 1;
  font-weight: 400;
}

.fav-active .fav-icon {
  color: #e5e7eb;
  font-weight: 400;
}

.cover-placeholder {
  width: 100%;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  font-size: 96rpx;
}

.body .hero-title {
  margin-bottom: 12rpx;
}

.price {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.spec-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.spec-item {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 16rpx;
  font-size: 24rpx;
}

.spec-item text {
  display: block;
}

.spec-item text:last-child {
  margin-top: 6rpx;
  font-weight: 600;
}

.action-btn {
  width: 100%;
  padding: 22rpx 28rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  background: transparent;
  border: 1rpx solid #d1d5db;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.hint {
  margin-top: 16rpx;
  font-size: 24rpx;
}
