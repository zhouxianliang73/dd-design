.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-actions button {
  flex: 1;
  margin: 0;
}

.ai-entry {
  margin-bottom: 24rpx;
}

.ai-entry:active {
  opacity: 0.9;
}

.ai-entry-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ai-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #111827, #374151);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-entry-body {
  flex: 1;
}

.ai-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.ai-arrow {
  font-size: 40rpx;
  color: #9ca3af;
  line-height: 1;
}

.designer-card {
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-header-title {
  font-size: 30rpx;
  font-weight: 600;
}

.card-header-more {
  font-size: 24rpx;
}

.designer-scroll {
  width: 100%;
}

.designer-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.designer-item {
  width: 160rpx;
  flex-shrink: 0;
  text-align: center;
}

.designer-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
  margin: 0 auto 12rpx;
  background: #e5e7eb;
}

.designer-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.designer-tag {
  font-size: 20rpx;
  line-height: 1.4;
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.case-card {
  padding: 0;
  overflow: hidden;
}

.case-cover {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #e5e7eb;
}

.case-cover-placeholder {
  width: 100%;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e5e7eb, #f3f4f6);
}

.case-cover-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 600;
}

.case-body {
  padding: 24rpx 28rpx 28rpx;
}

.case-tag {
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.case-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.case-summary {
  font-size: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 0 20rpx;
}

.section-title.inline {
  margin: 0;
}

.section-more {
  font-size: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.product-card {
  padding: 0;
  overflow: hidden;
}

.product-image-wrap {
  position: relative;
}

.product-fav {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  color: #e11d48;
  font-size: 28rpx;
  line-height: 48rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(17, 24, 39, 0.1);
}

.product-image {
  width: 100%;
  height: 220rpx;
  display: block;
  background: #e5e7eb;
}

.product-image-placeholder {
  width: 100%;
  height: 220rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.product-body {
  padding: 20rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.product-meta {
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}
