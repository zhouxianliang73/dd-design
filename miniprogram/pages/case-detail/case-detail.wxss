.cover {
  width: 100%;
  height: 420rpx;
  display: block;
  background: #e5e7eb;
}

.cover-placeholder {
  width: 100%;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e5e7eb, #f3f4f6);
  font-size: 32rpx;
  color: #6b7280;
  font-weight: 600;
}

.body {
  margin-top: -32rpx;
  position: relative;
}

.body .hero-title {
  margin: 12rpx 0;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 20rpx 0;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  background: #f3f4f6;
  border-radius: 999rpx;
  color: #4b5563;
}

.action-btn {
  width: 100%;
  margin-top: 8rpx;
}
